#!/usr/bin/env bash
set -e

ROOT="$(git rev-parse --show-toplevel)"

echo "==> Running app unit tests..."
cd "$ROOT/app"
npx vitest run

if [ -d "$ROOT/extension/src/__tests__" ]; then
  echo ""
  echo "==> Running extension unit tests..."
  cd "$ROOT/extension"
  npx vitest run
fi

echo ""
echo "==> All tests passed."
