# Copy this file to .env and fill in your API key
# Without the key, the app runs in demo mode with sample data

ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Cloudflare Tunnel token for public access via cookthedish.dev01.top
# Get from: Cloudflare Zero Trust > Networks > Tunnels > cookthedish
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
